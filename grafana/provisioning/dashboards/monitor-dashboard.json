  "panels": [
    {
      "type": "row",
      "title": "HTTP / HTTPS - Phasenverlauf",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "mappings": [],
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "DNS Resolve" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "Connect" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "TLS" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "Processing" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "Transfer" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "probe_http_duration_seconds{phase=\"resolve\", instance=~\"$instance\"} and on(instance) probe_success{instance=~\"$instance\"}",
          "legendFormat": "DNS Resolve - {{instance}}",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "probe_http_duration_seconds{phase=\"connect\", instance=~\"$instance\"} and on(instance) probe_success{instance=~\"$instance\"}",
          "legendFormat": "Connect - {{instance}}",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "probe_http_duration_seconds{phase=\"tls\", instance=~\"$instance\"} and on(instance) probe_success{instance=~\"$instance\"}",
          "legendFormat": "TLS - {{instance}}",
          "range": true,
          "refId": "C"
        },
        {
          "editorMode": "code",
          "expr": "probe_http_duration_seconds{phase=\"processing\", instance=~\"$instance\"} and on(instance) probe_success{instance=~\"$instance\"}",
          "legendFormat": "Processing - {{instance}}",
          "range": true,
          "refId": "D"
        },
        {
          "editorMode": "code",
          "expr": "probe_http_duration_seconds{phase=\"transfer\", instance=~\"$instance\"} and on(instance) probe_success{instance=~\"$instance\"}",
          "legendFormat": "Transfer - {{instance}}",
          "range": true,
          "refId": "E"
        }
      ],
      "title": "HTTP/HTTPS - Phasenverlauf (DNS, Connect, TLS, Processing, Transfer)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
